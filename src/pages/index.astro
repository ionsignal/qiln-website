---
import Base from "@/layouts/Base.astro";
import { fetchEntry } from "@/utils/content";
import HomeBanner from "@/components/sections/HomeBanner.astro";
import FeatureSplit from "@/components/sections/FeatureSplit.astro";
import Features from "@/components/sections/FeaturesSection.astro";
import CallToAction from "@/components/sections/CallToAction.astro";
import FaqSection from "@/components/sections/FaqSection.astro";
import BlueprintSection from "@/components/sections/BlueprintSection.astro";

const homepage = await fetchEntry("homepage", "-index");
const featureGpu = await fetchEntry("sections", "feature-gpu");
const featureStorage = await fetchEntry("sections", "feature-storage");
const blueprint = await fetchEntry("sections", "blueprint");
---

<Base {...homepage.data}>
  <HomeBanner />
  {
    featureGpu && (
      <FeatureSplit id="gpu" content={featureGpu.data} imagePosition="right" />
    )
  }
  {
    featureStorage && (
      <FeatureSplit
        id="storage"
        content={featureStorage.data}
        imagePosition="left"
      />
    )
  }
  {blueprint && <BlueprintSection content={blueprint.data} />}
  <Features />
  <FaqSection />
  <!-- <CallToAction /> -->
</Base>

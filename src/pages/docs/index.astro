---
import { getEntry, render } from "astro:content";
import FileTree from "@/components/shortcodes/FileTree.astro";
import Callout from "@/components/shortcodes/Callout.astro";
import Stepper from "@/components/shortcodes/Stepper.astro";
import Step from "@/components/shortcodes/Step.astro";
import Documentation from "@/layouts/Documentation.astro";

const entry = await getEntry("docs", "index");
if (!entry) {
  return Astro.redirect("/404");
}

const { Content, headings } = await render(entry);
---

<Documentation entry={entry} headings={headings}>
  <Content components={{ FileTree, Callout, Stepper, Step }} />
</Documentation>

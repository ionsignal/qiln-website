---
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"div"> {}

const { class: className, ...rest } = Astro.props;
---

<div
  class:list={[
    "file-tree not-prose my-6 overflow-x-auto rounded-lg border border-white/10 bg-white/5 p-4 font-mono text-sm",
    className,
  ]}
  {...rest}>
  <slot />
</div>

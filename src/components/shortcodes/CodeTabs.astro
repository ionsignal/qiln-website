---
interface Props {
  syncKey?: string;
  label?: string;
}

const { syncKey, label } = Astro.props;
const groupId = crypto.randomUUID().slice(0, 8);
const tablistLabel = label ?? "Code examples";
---

<div
  class="qiln-code-tabs"
  data-group-id={groupId}
  data-sync-key={syncKey ?? ""}
  data-label={tablistLabel}>
  <slot />
</div>

<script>
  import { HSTabs } from "preline";
  import copyIconRaw from "@/assets/images/icons/copy.svg?raw";
  import checkIconRaw from "@/assets/images/icons/check.svg?raw";

  const STORAGE_PREFIX = "qiln:tabs:";

  let cachedIcons: { copy: SVGElement; check: SVGElement } | null = null;
  function getIcons() {
    if (cachedIcons) return cachedIcons;
    const tpl = document.createElement("template");
    tpl.innerHTML = copyIconRaw + checkIconRaw;
    const [copy, check] = tpl.content.querySelectorAll("svg");
    cachedIcons = { copy: copy as SVGElement, check: check as SVGElement };
    return cachedIcons;
  }

  function readStored(syncKey: string): string | null {
    try {
      return localStorage.getItem(STORAGE_PREFIX + syncKey);
    } catch {
      return null;
    }
  }

  function writeStored(syncKey: string, slug: string): void {
    try {
      localStorage.setItem(STORAGE_PREFIX + syncKey, slug);
    } catch {
      // private mode / quota — silent fallback
    }
  }

  function buildCopyButton(): HTMLButtonElement {
    const btn = document.createElement("button");
    btn.type = "button";
    btn.className = "qiln-copy";
    btn.setAttribute("aria-label", "Copy code");

    const iconWrap = document.createElement("span");
    iconWrap.className = "qiln-copy__icon";
    iconWrap.setAttribute("aria-hidden", "true");

    // aria-live only announces on content mutation, not when injected
    // pre-populated. Persist the region empty; mutate textContent on
    // success/reset.
    const live = document.createElement("span");
    live.className = "sr-only";
    live.setAttribute("aria-live", "polite");
    live.setAttribute("aria-atomic", "true");

    btn.appendChild(iconWrap);
    btn.appendChild(live);

    iconWrap.replaceChildren(getIcons().copy.cloneNode(true));
    return btn;
  }

  function bindCopyClick(root: HTMLElement, btn: HTMLButtonElement) {
    const iconWrap = btn.querySelector<HTMLElement>(".qiln-copy__icon");
    const liveRegion = btn.querySelector<HTMLElement>(".sr-only");
    if (!iconWrap || !liveRegion) return;

    let resetTimer: number | undefined;
    btn.addEventListener("click", async () => {
      const icons = getIcons();
      // Read the active panel at click time so it stays correct after switches.
      const active = root.querySelector<HTMLElement>(
        '[role="tabpanel"]:not(.hidden)',
      );
      const text = active?.querySelector("pre")?.textContent ?? "";
      try {
        await navigator.clipboard.writeText(text);
        iconWrap.replaceChildren(icons.check.cloneNode(true));
        btn.classList.add("qiln-copy--success");
        liveRegion.textContent = "Copied";
      } catch {
        iconWrap.replaceChildren(icons.copy.cloneNode(true));
        btn.classList.remove("qiln-copy--success");
        liveRegion.textContent = "Copy failed";
      }
      if (resetTimer) clearTimeout(resetTimer);
      resetTimer = window.setTimeout(() => {
        iconWrap.replaceChildren(icons.copy.cloneNode(true));
        btn.classList.remove("qiln-copy--success");
        liveRegion.textContent = "";
      }, 2000);
    });
  }

  function bindChangeHandler(root: HTMLElement, tablist: HTMLElement) {
    const wrapper = HSTabs.getInstance(tablist, true) as
      | { element?: { on: (event: string, cb: (payload: any) => void) => void } }
      | null;
    const instance = wrapper?.element;
    if (!instance || typeof instance.on !== "function") return;

    const syncKey = root.dataset.syncKey;

    // Restore from localStorage (one-time per init, only when sync is enabled).
    if (syncKey) {
      const stored = readStored(syncKey);
      if (stored) {
        const target = root.querySelector<HTMLElement>(
          `[role="tab"][data-slug="${CSS.escape(stored)}"]`,
        );
        const currentActive = root.querySelector<HTMLElement>(
          '[role="tab"][aria-selected="true"]',
        );
        if (target && target !== currentActive) HSTabs.open(target);
      }
    }

    instance.on("change", ({ el }: { el: HTMLElement }) => {
      const slug = el?.dataset?.slug;
      if (!slug) return;

      // Roving tabindex: only the active tab is in the Tab sequence.
      root
        .querySelectorAll<HTMLElement>('[role="tab"]')
        .forEach((t) => (t.tabIndex = t.dataset.slug === slug ? 0 : -1));

      if (!syncKey) return;
      writeStored(syncKey, slug);

      // Peer sync (defense-in-depth recursion guard).
      document
        .querySelectorAll<HTMLElement>(
          `.qiln-code-tabs[data-sync-key="${CSS.escape(syncKey)}"]`,
        )
        .forEach((peer) => {
          if (peer === root) return;
          const peerActive = peer.querySelector<HTMLElement>(
            '[role="tab"][aria-selected="true"]',
          );
          if (peerActive?.dataset.slug === slug) return;
          const peerTarget = peer.querySelector<HTMLElement>(
            `[role="tab"][data-slug="${CSS.escape(slug)}"]`,
          );
          if (peerTarget) HSTabs.open(peerTarget);
        });
    });
  }

  function processGroup(root: HTMLElement) {
    if (root.dataset.qilnReady === "true") return;
    if (typeof HSTabs === "undefined") return;

    const groupId = root.dataset.groupId!;
    const tablistLabel = root.dataset.label || "Code examples";
    const panels = Array.from(
      root.querySelectorAll<HTMLElement>(":scope > [data-code-tab]"),
    );
    if (panels.length === 0) return;

    // Slug uniqueness pass.
    const used = new Set<string>();
    const meta = panels.map((el, i) => {
      let slug = (el.dataset.slug || "").trim();
      if (!slug) slug = `tab-${i}`;
      let final = slug;
      let n = 2;
      while (used.has(final)) final = `${slug}-${n++}`;
      used.add(final);

      el.dataset.slug = final;
      el.id = `panel-${groupId}-${final}`;
      el.setAttribute("role", "tabpanel");
      el.setAttribute("aria-labelledby", `tab-${groupId}-${final}`);
      if (i !== 0) el.classList.add("hidden");

      return {
        el,
        slug: final,
        label: el.dataset.label || "",
        icon: el.dataset.icon || "",
      };
    });

    // Build tablist (HSTabs-shaped: data-hs-tab points at panel selector).
    const nav = document.createElement("nav");
    nav.setAttribute("role", "tablist");
    nav.setAttribute("aria-label", tablistLabel);
    nav.className = "qiln-code-tabs__tabs";
    meta.forEach(({ slug, label }, i) => {
      const btn = document.createElement("button");
      btn.type = "button";
      btn.id = `tab-${groupId}-${slug}`;
      btn.className = `qiln-code-tabs__tab${i === 0 ? " active" : ""}`;
      btn.setAttribute("role", "tab");
      btn.setAttribute("data-hs-tab", `#panel-${groupId}-${slug}`);
      btn.dataset.slug = slug;
      btn.setAttribute("aria-controls", `panel-${groupId}-${slug}`);
      btn.setAttribute("aria-selected", i === 0 ? "true" : "false");
      btn.tabIndex = i === 0 ? 0 : -1;
      btn.textContent = label;
      nav.appendChild(btn);
    });

    // __row wrapper holds tablist + copy button as siblings (WAI-ARIA: tablist
    // owns only role=tab children, so the copy button must not be inside it).
    const row = document.createElement("div");
    row.className = "qiln-code-tabs__row";
    row.appendChild(nav);
    const copyBtn = buildCopyButton();
    row.appendChild(copyBtn);

    // Order matters: insert tablist FIRST, then promote root to ready (CSS
    // gate releases), then call HSTabs.autoInit() so it picks up the new nav.
    root.prepend(row);
    bindCopyClick(root, copyBtn);
    root.dataset.qilnReady = "true";
    HSTabs.autoInit();
    bindChangeHandler(root, nav);
  }

  let storageListenerBound = false;
  function bindStorageListener() {
    if (storageListenerBound) return;
    storageListenerBound = true;
    window.addEventListener("storage", (e: StorageEvent) => {
      if (!e.key?.startsWith(STORAGE_PREFIX) || !e.newValue) return;
      const syncKey = e.key.slice(STORAGE_PREFIX.length);
      const slug = e.newValue;
      document
        .querySelectorAll<HTMLElement>(
          `.qiln-code-tabs[data-sync-key="${CSS.escape(syncKey)}"]`,
        )
        .forEach((root) => {
          const peerActive = root.querySelector<HTMLElement>(
            '[role="tab"][aria-selected="true"]',
          );
          if (peerActive?.dataset.slug === slug) return;
          const target = root.querySelector<HTMLElement>(
            `[role="tab"][data-slug="${CSS.escape(slug)}"]`,
          );
          if (target) HSTabs.open(target);
        });
    });
  }

  function onReady() {
    bindStorageListener();
    document
      .querySelectorAll<HTMLElement>(".qiln-code-tabs")
      .forEach(processGroup);
  }

  if (document.readyState !== "loading") {
    onReady();
  } else {
    document.addEventListener("DOMContentLoaded", onReady);
  }
  document.addEventListener("astro:page-load", onReady);
</script>

---
import { useTranslations } from "@/utils/core";
import LucideIcon from "@/components/helpers/LucideIcon.astro";

interface Props {
  formAction?: string;
  layout?: "hero" | "footer";
  idSuffix?: string;
  [key: string]: any;
}

const t = useTranslations();
const { formAction, layout = "footer", idSuffix = "footer" } = Astro.props;
const isHero = layout === "hero";
---

<style>
  .morph-container.notransition,
  .morph-container.notransition * {
    transition: none !important;
  }
</style>

{
  isHero ? (
    <div
      id="early-testers"
      class="morph-container group relative mx-auto h-14 w-full max-w-72 transition-[max-width,width] duration-500 ease-out lg:mx-0 [&.is-expanded]:w-full [&.is-expanded]:max-w-full [&.is-expanded]:sm:w-95">
      <button
        type="button"
        class="morph-trigger btn btn-md btn-solid-primary btn-has-icon absolute inset-0 z-10 flex size-full items-center justify-center gap-4 font-bold transition-all duration-500 ease-out group-[.is-expanded]:pointer-events-none group-[.is-expanded]:z-0 group-[.is-expanded]:scale-95 group-[.is-expanded]:opacity-0">
        <span class="label z-20">{t("navigation.buttonLabel")}</span>
      </button>
      <form
        action={formAction}
        id={`mc-embedded-subscribe-form-${idSuffix}`}
        method="post"
        class="subscribe-form morph-target pointer-events-none absolute inset-0 z-0 size-full scale-95 opacity-0 transition-all duration-500 ease-out group-[.is-expanded]:pointer-events-auto group-[.is-expanded]:z-10 group-[.is-expanded]:scale-100 group-[.is-expanded]:opacity-100">
        <label for={`mce-EMAIL-${idSuffix}`} class="sr-only">
          Email
        </label>
        <input
          required
          type="email"
          name="EMAIL"
          id={`mce-EMAIL-${idSuffix}`}
          aria-required="true"
          placeholder={t("common.emailPlaceholder")}
          class="border-primary/80 focus:ring-primary/15 size-full rounded-full border-2 bg-white/10 py-4 pr-40 pl-5 text-white shadow-none outline-0 backdrop-blur-sm transition-all duration-300 placeholder:text-white/80 focus:ring-4"
        />
        <div class="absolute top-1 right-1 flex h-[calc(100%-0.5rem)] items-center gap-1 sm:gap-2">
          <button
            type="button"
            aria-label="Cancel"
            class="morph-cancel flex h-8 w-8 items-center justify-center rounded-full text-white/50 transition-colors duration-200 hover:bg-white/10 hover:text-white focus:ring-2 focus:ring-white/20 focus:outline-none">
            <LucideIcon icon="X" class="h-5 w-5" />
          </button>
          <button
            type="submit"
            name="subscribe"
            id={`mc-embedded-subscribe-${idSuffix}`}
            class="btn-solid-primary has-icon-moving-animation flex h-full w-24 items-center justify-center rounded-full">
            <span class="sr-only">Subscribe</span>
            <span class="icons-wrapper inline-flex h-10 w-10 items-center justify-center">
              <span class="icon icon-before flex items-center justify-center">
                <LucideIcon icon="ArrowUpRight" class="h-6 w-6 text-white" />
              </span>
              <span class="icon icon-after flex items-center justify-center">
                <LucideIcon icon="ArrowUpRight" class="h-6 w-6 text-white" />
              </span>
            </span>
          </button>
        </div>
        <div class="messages-container clear absolute top-[125%] left-0 w-full text-sm opacity-60">
          <div class="message-error text-red-400" style="display: none" />
          <div class="message-success text-green-400" style="display: none" />
        </div>
        <div style="position: absolute; left: -312.5rem" aria-hidden="true">
          <input
            type="text"
            name="b_436cb8647d746fe81825f1efc_18a007239a"
            tabindex="-1"
            value=""
          />
        </div>
        <input
          type="hidden"
          name="EMAILTYPE"
          id={`mce-EMAILTYPE-0-${idSuffix}`}
          value="html"
        />
        <span class="sr-only">gats-upstart</span>
      </form>
    </div>
  ) : (
    <form
      action={formAction}
      id={`mc-embedded-subscribe-form-${idSuffix}`}
      method="post"
      class="subscribe-form relative">
      <label for={`mce-EMAIL-${idSuffix}`} class="sr-only">
        Email
      </label>
      <input
        required
        type="email"
        name="EMAIL"
        id={`mce-EMAIL-${idSuffix}`}
        aria-required="true"
        placeholder={t("common.emailPlaceholder")}
        class="border-primary/80 focus:ring-primary/15 size-full rounded-full bg-white/5 py-4 pr-28 pl-5 shadow-none outline-0 transition-all duration-300 placeholder:text-white placeholder:opacity-90 focus:ring-4"
      />
      <button
        type="submit"
        name="subscribe"
        id={`mc-embedded-subscribe-${idSuffix}`}
        class="btn-solid-primary has-icon-moving-animation absolute top-1 right-1 flex h-[calc(100%-0.5rem)] w-24 items-center justify-center rounded-full">
        <span class="sr-only">Subscribe</span>
        <span class="icons-wrapper inline-flex h-10 w-10 items-center justify-center">
          <span class="icon icon-before flex items-center justify-center">
            <LucideIcon icon="ArrowUpRight" class="h-6 w-6 text-white" />
          </span>
          <span class="icon icon-after flex items-center justify-center">
            <LucideIcon icon="ArrowUpRight" class="h-6 w-6 text-white" />
          </span>
        </span>
      </button>
      <div class="messages-container clear absolute top-[125%] left-0 w-full text-sm opacity-60">
        <div class="message-error text-red-400" style="display: none" />
        <div class="message-success text-green-400" style="display: none" />
      </div>
      <div style="position: absolute; left: -312.5rem" aria-hidden="true">
        <input
          type="text"
          name="b_436cb8647d746fe81825f1efc_18a007239a"
          tabindex="-1"
          value=""
        />
      </div>
      <input
        type="hidden"
        name="EMAILTYPE"
        id={`mce-EMAILTYPE-0-${idSuffix}`}
        value="html"
      />
      <span class="sr-only">gats-upstart</span>
    </form>
  )
}

<script>
  interface JsonpResponse {
    result: "success" | "error";
    msg: string;
    type?: string;
    webEngagementCookieValue?: string | null;
  }
  document.addEventListener("DOMContentLoaded", () => {
    function expandMorphContainers() {
      const morphContainers = document.querySelectorAll(".morph-container");
      morphContainers.forEach((container) => {
        container.classList.add("is-expanded");
        const input = container.querySelector(
          'input[type="email"]',
        ) as HTMLInputElement | null;
        if (input) setTimeout(() => input.focus(), 500);
      });
    }
    if (window.location.hash === "#early-testers") {
      expandMorphContainers();
    }
    document.querySelectorAll(".morph-container").forEach((container) => {
      const trigger = container.querySelector(".morph-trigger");
      if (trigger) {
        trigger.addEventListener("click", () => {
          container.classList.add("is-expanded");
          const input = container.querySelector(
            'input[type="email"]',
          ) as HTMLInputElement | null;
          if (input) setTimeout(() => input.focus(), 500);
        });
      }
    });
    document.querySelectorAll(".morph-cancel").forEach((cancelBtn) => {
      cancelBtn.addEventListener("click", (e) => {
        e.stopPropagation();
        const container = cancelBtn.closest(".morph-container") as HTMLElement;
        if (container) {
          container.classList.add("notransition");
          container.classList.remove("is-expanded");
          const input = container.querySelector(
            'input[type="email"]',
          ) as HTMLInputElement | null;
          if (input) {
            input.value = "";
            input.blur();
          }
          if (window.location.hash === "#early-testers") {
            history.replaceState(
              null,
              "",
              window.location.pathname + window.location.search,
            );
          }
          void container.offsetHeight;
          container.classList.remove("notransition");
        }
      });
    });
    // Global Intercept (Clicking the Navbar button)
    document.addEventListener("click", (e) => {
      const target = e.target as HTMLElement;
      const link = target.closest('a[href$="#early-testers"]');
      if (link) {
        const morphContainers = document.querySelectorAll(".morph-container");
        if (morphContainers.length > 0) {
          e.preventDefault();
          window.scrollTo({ top: 0, behavior: "smooth" });
          expandMorphContainers();
        }
      }
    });
  });
  document
    .querySelectorAll<HTMLFormElement>(".subscribe-form")
    .forEach((form) => {
      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        const targetForm = event.target as HTMLFormElement;
        const formData = new FormData(targetForm);
        const actionUrl = targetForm.getAttribute("action");
        if (!actionUrl) {
          console.error("Form action URL is missing.");
          return;
        }
        const queryString = new URLSearchParams(formData as any).toString();
        const errorContainer =
          targetForm.querySelector<HTMLElement>(".message-error");
        const successContainer =
          targetForm.querySelector<HTMLElement>(".message-success");
        if (!errorContainer || !successContainer) {
          console.error("Error or success response containers are missing.");
          return;
        }
        errorContainer.style.display = "none";
        successContainer.style.display = "none";
        try {
          const script = document.createElement("script");
          const callbackName = `jsonpCallback_${Date.now()}_${Math.floor(Math.random() * 1000)}`;
          (window as any)[callbackName] = (data: JsonpResponse) => {
            if (data.result === "success") {
              successContainer.textContent =
                data.msg || "Thank you for subscribing!";
              successContainer.style.display = "block";
            } else {
              errorContainer.textContent =
                data.msg || "An error occurred. Please try again.";
              errorContainer.style.display = "block";
            }
            delete (window as any)[callbackName];
            script.remove();
          };
          script.src = `${actionUrl}&c=${callbackName}&${queryString}`;
          script.onerror = () => {
            errorContainer.textContent =
              "There was an error processing your request. Please try again later.";
            errorContainer.style.display = "block";
            console.error("Error loading JSONP script.");
          };
          document.body.appendChild(script);
        } catch (error) {
          errorContainer.textContent =
            "There was an error processing your request. Please try again later.";
          errorContainer.style.display = "block";
          console.error("Error:", error);
        }
      });
    });
</script>

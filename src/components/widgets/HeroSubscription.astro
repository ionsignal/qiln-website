---
import { useTranslations } from "@/utils/core";
import LucideIcon from "@/components/helpers/LucideIcon.astro";
import config from ".astro/config.generated.json";

interface Props {
  formAction?: string;
}

const { formAction } = Astro.props;
const t = useTranslations();
const actionUrl = formAction || config.settings.subscription.formAction;
const msgs = {
  success: "Thank you for joining our early testers!",
  error: "An error occurred. Please try again.",
  network: "Network error. Please try again later.",
};
---

<qiln-subscribe
  id="early-testers"
  aria-expanded="false"
  data-action={actionUrl}
  data-msg-success={msgs.success}
  data-msg-error={msgs.error}
  data-msg-network={msgs.network}
  data-status="idle"
  class="group relative mx-auto block h-14 w-full max-w-72 transition-[max-width,width] duration-500 ease-out aria-expanded:max-w-full aria-expanded:sm:w-95 lg:mx-0">
  <button
    type="button"
    class="morph-trigger btn btn-md btn-solid-primary btn-has-icon absolute inset-0 z-10 flex size-full items-center justify-center gap-4 font-bold transition-all duration-500 ease-out group-aria-expanded:pointer-events-none group-aria-expanded:z-0 group-aria-expanded:scale-95 group-aria-expanded:opacity-0">
    <span class="label z-20">{t("navigation.buttonLabel")}</span>
  </button>
  <form
    class="absolute inset-0 z-0 size-full scale-95 opacity-0 transition-all duration-500 ease-out group-aria-expanded:pointer-events-auto group-aria-expanded:z-10 group-aria-expanded:scale-100 group-aria-expanded:opacity-100">
    <label for="email-hero" class="sr-only">Email</label>
    <input
      required
      type="email"
      name="email"
      id="email-hero"
      aria-required="true"
      placeholder={t("common.emailPlaceholder")}
      class="border-primary/80 focus:ring-primary/15 size-full rounded-full border-2 bg-white/10 py-4 pr-40 pl-5 text-white shadow-none outline-0 backdrop-blur-sm transition-all duration-300 group-data-[status=error]:border-red-500 group-data-[status=error]:text-red-100 placeholder:text-white/80 focus:ring-4 group-data-[status=error]:focus:ring-red-500/20 disabled:opacity-50 disabled:group-data-[status=success]:cursor-default disabled:group-data-[status=success]:border-teal-500 disabled:group-data-[status=success]:bg-teal-500/10 disabled:group-data-[status=success]:text-teal-400 disabled:group-data-[status=success]:opacity-100"
    />
    <div
      class="absolute top-1 right-1 flex h-[calc(100%-0.5rem)] items-center gap-1 sm:gap-2">
      <button
        type="button"
        aria-label="Cancel"
        class="morph-cancel flex h-8 w-8 items-center justify-center rounded-full text-white/50 transition-colors duration-200 hover:bg-white/10 hover:text-white focus:ring-2 focus:ring-white/20 focus:outline-none">
        <LucideIcon icon="X" class="h-5 w-5" />
      </button>
      <button
        type="submit"
        class="btn-solid-primary has-icon-moving-animation flex h-full w-24 items-center justify-center rounded-full disabled:cursor-not-allowed disabled:opacity-70 disabled:group-data-[status=success]:cursor-default disabled:group-data-[status=success]:bg-teal-600 disabled:group-data-[status=success]:opacity-100">
        <span class="sr-only">Subscribe</span>
        <span
          class="icons-wrapper inline-flex h-10 w-10 items-center justify-center">
          <span class="icon icon-before flex items-center justify-center">
            <LucideIcon icon="ArrowUpRight" class="h-6 w-6 text-white" />
          </span>
          <span class="icon icon-after flex items-center justify-center">
            <LucideIcon icon="ArrowUpRight" class="h-6 w-6 text-white" />
          </span>
        </span>
      </button>
    </div>
    <div
      class="messages-container absolute top-full left-0 w-full text-sm opacity-90">
      <div
        class="message-feedback hidden group-data-[status=error]:text-red-400 group-data-[status=success]:text-teal-400"
        aria-live="polite">
      </div>
    </div>
  </form>
</qiln-subscribe>

<script>
  import { QilnSubscribe } from "@/utils/subscribe";
  if (!customElements.get("qiln-subscribe")) {
    customElements.define("qiln-subscribe", QilnSubscribe);
  }
</script>

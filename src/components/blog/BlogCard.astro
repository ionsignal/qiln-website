---
import { render, getEntry } from "astro:content";
import Image from "@/components/helpers/Image.astro";
import LucideIcon from "@/components/helpers/LucideIcon.astro";
import { formatUrl } from "@/utils/core";
import type { CollectionEntry } from "astro:content";
import type { RemarkPluginFrontmatter } from "@/types";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;

// SSG Optimized: We call render() here to extract the injected remark frontmatter
const { remarkPluginFrontmatter } = await render(post);
const { minutesRead } = remarkPluginFrontmatter as RemarkPluginFrontmatter;

// Resolve the relational author data
let authorData = null;
if (post.data.author) {
  authorData = await getEntry(post.data.author);
}

const formattedDate = post.data.pubDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<article
  class="group relative flex flex-col items-start justify-between rounded-2xl border border-white/10 bg-white/5 p-4 transition-colors duration-300 hover:bg-white/10">
  <div class="relative mb-4 aspect-video w-full overflow-hidden rounded-xl">
    <Image
      src={post.data.image}
      alt={post.data.title}
      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
    />
  </div>
  <div class="text-text-default/80 mb-3 flex items-center gap-x-4 text-xs">
    <time datetime={post.data.pubDate.toISOString()}>{formattedDate}</time>
    <span class="flex items-center gap-1">
      <LucideIcon icon="Clock" class="h-3 w-3" />
      {minutesRead}
    </span>
  </div>
  <h3
    class="group-hover:text-primary mb-2 text-xl font-semibold text-white transition-colors">
    <a href={formatUrl(`/blog/${post.id}`)}>
      <span class="absolute inset-0"></span>
      {post.data.title}
    </a>
  </h3>
  <p class="text-text-default mb-4 line-clamp-3 text-sm">
    {post.data.description}
  </p>

  {
    authorData && (
      <div class="relative mt-auto flex w-full items-center gap-x-3 border-t border-white/10 pt-4">
        <Image
          src={authorData.data.avatar}
          alt={authorData.data.name}
          class="h-8 w-8 rounded-full bg-white/10"
        />
        <div class="text-sm leading-6">
          <p class="font-semibold text-white">
            <span class="absolute inset-0" />
            {authorData.data.name}
          </p>
        </div>
      </div>
    )
  }
</article>

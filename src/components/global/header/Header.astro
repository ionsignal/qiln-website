---
import Logo from "@/components/global/Logo.astro";
import config from ".astro/config.generated.json";
import NavigationButton from "@/components/global/header/NavigationButton.astro";
import NavMenuItem from "@/components/global/header/MenuItem.astro";
import NavToggleBtn from "@/components/global/header/NavToggleBtn.astro";
import SocialChips from "@/components/social/SocialChips.astro";
import { useTranslations, sortByWeight, filteredEnabled } from "@/utils/core";
import { headerSocials } from "@/utils/socials";
import type { NavigationLink } from "@/types";

const t = useTranslations();
let main = t("main");
main = filteredEnabled(main);
main = sortByWeight(main) as NavigationLink[];
const {
  site: { logoHoverAnimation },
  settings: { stickyHeader, navigationButton },
} = config;
---

<header
  class:list={[
    "header group/header mt-5 transform",
    { "sticky-header": stickyHeader },
  ]}>
  <div class="relative mx-auto w-full px-5 xl:container xl:px-4">
    <nav
      class="bg-theme-dark/80 relative flex items-center justify-between gap-2 px-2 py-2.5 backdrop-blur-md max-lg:rounded-none lg:rounded-full">
      <Logo
        class={logoHoverAnimation ? "has-hover-animation" : ""}
        loading="eager"
      />
      <div
        id="nav-menu"
        class="hs-collapse hidden grow basis-full overflow-hidden transition-all duration-300 max-lg:absolute max-lg:top-full max-lg:left-0 max-lg:z-40 max-lg:w-full lg:block lg:w-auto lg:basis-auto">
        <ul class="navbar has-customized-scrollbar">
          {main.map((menu) => <NavMenuItem menu={menu} />)}
          {
            navigationButton.enable && (
              <li class="max-lg:px-4 max-lg:py-2 lg:hidden" role="menuitem">
                {navigationButton.enable && (
                  <NavigationButton
                    navigationButton={navigationButton}
                    navigationbuttonLabel={t("navigation.buttonLabel")}
                  />
                )}
              </li>
            )
          }
          {
            headerSocials.length > 0 && (
              <li class="mt-1 border-t border-white/10 px-4 pt-3 lg:hidden">
                <SocialChips
                  links={headerSocials}
                  class="gap-2"
                  anchorClass="text-text-default hover:text-light focus-visible:ring-primary/60 inline-flex h-11 w-11 items-center justify-center rounded-full bg-white/5 ring-1 ring-white/10 transition-colors duration-150 hover:bg-white/10 hover:ring-white/20 focus-visible:ring-2 focus-visible:outline-none"
                  iconClass="h-5 w-5"
                />
              </li>
            )
          }
        </ul>
      </div>
      {
        (headerSocials.length > 0 || navigationButton.enable) && (
          <div class="hidden items-center gap-2 max-lg:me-4 max-lg:ml-auto lg:flex">
            <SocialChips
              links={headerSocials}
              class="gap-1"
              anchorClass="group text-text-default hover:text-light focus-visible:ring-primary/60 inline-flex h-9 w-9 items-center justify-center rounded-full transition-colors duration-200 hover:bg-white/5 focus-visible:ring-2 focus-visible:outline-none"
              iconClass="h-[18px] w-[18px] transition-transform duration-200 group-hover:scale-110"
            />
            {headerSocials.length > 0 && navigationButton.enable && (
              <span
                class="mx-1 h-5 w-px self-center bg-white/10"
                aria-hidden="true"
              />
            )}
            {navigationButton.enable && (
              <NavigationButton
                navigationButton={navigationButton}
                navigationbuttonLabel={t("navigation.buttonLabel")}
              />
            )}
          </div>
        )
      }
      <NavToggleBtn />
    </nav>
  </div>
</header>
<script>
  document.addEventListener("click", (event: MouseEvent) => {
    const navMenu = document.getElementById("nav-menu");
    const navToggler = document.querySelector(
      ".nav-toggler",
    ) as HTMLElement | null;
    if (navMenu && navMenu.classList.contains("open")) {
      const target = event.target as Element;
      const clickedLink = target.closest("a");
      const isOutsideClick =
        !navMenu.contains(target) && navToggler && !navToggler.contains(target);
      const isInsideLinkClick =
        navMenu.contains(target) && clickedLink !== null;
      if (isOutsideClick || isInsideLinkClick) {
        navToggler?.click();
      }
    }
  });
</script>

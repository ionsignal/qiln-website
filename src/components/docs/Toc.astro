---
import type { DocEntry, DocTocNode } from "@/types/docs";
import type { MarkdownHeading } from "astro";

interface Props {
  headings: MarkdownHeading[];
  entry: DocEntry;
}

const { headings, entry } = Astro.props;
const tocEnabled = entry.data.tableOfContents !== false;
const minLevel = entry.data.tocMinLevel;
const maxLevel = entry.data.tocMaxLevel;

function buildTocTree(items: MarkdownHeading[]): DocTocNode[] {
  const roots: DocTocNode[] = [];
  const stack: DocTocNode[] = [];
  for (const h of items) {
    const node: DocTocNode = {
      slug: h.slug,
      text: h.text,
      depth: h.depth,
      children: [],
    };
    while (stack.length > 0 && stack[stack.length - 1].depth >= node.depth) {
      stack.pop();
    }
    if (stack.length === 0) roots.push(node);
    else stack[stack.length - 1].children.push(node);
    stack.push(node);
  }
  return roots;
}

function escapeHtml(value: string): string {
  return value.replace(/[&<>"']/g, (ch) => {
    switch (ch) {
      case "&":
        return "&amp;";
      case "<":
        return "&lt;";
      case ">":
        return "&gt;";
      case '"':
        return "&quot;";
      default:
        return "&#39;";
    }
  });
}

function renderTree(nodes: DocTocNode[], nested: boolean): string {
  const listClass = nested
    ? "docs-toc-list docs-toc-list-nested"
    : "docs-toc-list";
  const items = nodes
    .map((node) => {
      const children =
        node.children.length > 0 ? renderTree(node.children, true) : "";
      const slug = escapeHtml(node.slug);
      const text = escapeHtml(node.text);
      return `<li class="docs-toc-item"><a href="#${slug}" class="docs-toc-link" data-docs-toc-link="${slug}">${text}</a>${children}</li>`;
    })
    .join("");
  return `<ul class="${listClass}">${items}</ul>`;
}

const filtered = tocEnabled
  ? headings.filter((h) => h.depth >= minLevel && h.depth <= maxLevel)
  : [];
const tree = buildTocTree(filtered);
const shouldRender = tocEnabled && tree.length > 0;
const treeHtml = shouldRender ? renderTree(tree, false) : "";
---

{
  shouldRender && (
    <nav
      class="docs-toc has-customized-scrollbar"
      data-hs-scrollspy="#docs-content"
      style="--scrollspy-offset: 120;"
      aria-label="On this page">
      <p class="docs-toc-title">On this page</p>
      <Fragment set:html={treeHtml} />
    </nav>
  )
}

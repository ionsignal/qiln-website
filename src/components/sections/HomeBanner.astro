---
import config from ".astro/config.generated.json";
import Image from "@/components/helpers/Image.astro";
import SvgIcon from "@/components/helpers/SvgIcon.astro";
import BlueprintsScroller from "@/components/sections/BlueprintsScroller.astro";
import ButtonLink from "@/components/buttons/ButtonLink.astro";
import AnimatedText from "@/components/widgets/AnimatedText.astro";
import HeroSubscription from "@/components/widgets/HeroSubscription.astro";
import Visualization from "@/components/widgets/Visualization.astro";
import { plainify } from "@/utils/text";
import { overrideObjects } from "@/utils/core";
import { markdownify } from "@/utils/text";
import { fetchEntry } from "@/utils/content";
import type { CollectionEntry } from "astro:content";

type SectionData = CollectionEntry<"sections">["data"];
type Props = {
  content?: SectionData;
};

let defaultContent = (await fetchEntry("sections", "home-banner"))?.data;
let actualContent = overrideObjects({ ...defaultContent }, Astro.props.content);
let {
  title,
  subtitle,
  badge,
  customers,
  description,
  image,
  buttons,
  subscription,
} = actualContent;

function parseTickerString(rawTitle: string | undefined) {
  if (!rawTitle) return { isTicker: false };
  const match = rawTitle.match(/^(.*?)\[(.*?)\](.*)$/);
  if (match) {
    const prefix = match[1].trim();
    const options = match[2]
      .split("|")
      .map((s) => s.trim())
      .filter(Boolean);
    const suffix = match[3].trim();
    if (options.length > 1) {
      const longestOption = options.reduce(
        (a, b) => (a.length > b.length ? a : b),
        "",
      );
      const fallbackTitle = `${prefix} ${options[0]} ${suffix}`.trim();
      return {
        isTicker: true,
        prefix,
        options,
        suffix,
        longestOption,
        fallbackTitle,
      };
    }
  }
  return { isTicker: false };
}

const tickerData = parseTickerString(title);
---

<section id="home" class="scroll-mt-24 lg:scroll-mt-32">
  <div
    class="banner-gradient stretched-link relative pt-12 md:pt-12 lg:pt-16 xl:pt-24">
    <Visualization />
    <div class="container">
      <div class="relative z-10 mx-auto max-w-4xl space-y-10">
        <div class="flex flex-col items-center gap-y-8 text-center md:gap-y-10">
          {
            badge && (
              <div
                class="animated-text"
                data-duration="0.6"
                data-delay="0.2"
                data-stagger="0.1">
                <div class="word inline-flex items-center rounded-lg border border-white/7.5 px-3.5 py-1.5">
                  <span
                    aria-hidden="true"
                    class="text-center text-xs tracking-wider text-white/50 uppercase sm:text-sm">
                    {badge}
                  </span>
                </div>
              </div>
            )
          }
          <div class="relative inline-block w-full">
            {
              (title || subtitle) && (
                <h1 class="has-italic-text font-secondary mx-auto flex flex-col gap-y-2 text-center text-3xl text-white md:gap-y-4 md:text-5xl/tight lg:text-6xl/tight">
                  {tickerData.isTicker ? (
                    <>
                      <span
                        class="sr-only"
                        set:html={markdownify(tickerData.fallbackTitle)}
                      />
                      <qiln-ticker aria-hidden="true" class="inline">
                        {tickerData.prefix && (
                          <span set:html={markdownify(tickerData.prefix)} />
                        )}
                        <span class="text-primary relative isolate z-0 -mx-3 inline-flex items-baseline gap-0 px-0 py-0 align-baseline whitespace-nowrap">
                          <span class="ticker-container relative z-10 inline-grid items-baseline justify-items-center overflow-hidden">
                            <span class="invisible col-start-1 row-start-1">
                              {tickerData.longestOption}
                            </span>
                            {tickerData.options?.map((opt, i) => (
                              <span
                                class:list={[
                                  "ticker-item col-start-1 row-start-1 will-change-[transform,filter,opacity]",
                                  i === 0 ? "opacity-100" : "opacity-0",
                                ]}>
                                {opt}
                              </span>
                            ))}
                          </span>
                        </span>
                        {tickerData.suffix && (
                          <span set:html={markdownify(tickerData.suffix)} />
                        )}
                      </qiln-ticker>
                    </>
                  ) : (
                    title && <span set:html={markdownify(title)} />
                  )}
                  {subtitle && (
                    <span
                      class="text-xl font-bold text-white/80 md:text-4xl lg:text-5xl"
                      set:html={markdownify(subtitle)}
                    />
                  )}
                </h1>
              )
            }
          </div>
          {
            description && (
              <AnimatedText
                class="[&_strong]:text-secondary [&_b]:text-secondary mx-auto max-w-3xl text-center text-lg/normal text-white/90 [&_strong]:font-bold"
                stagger={0.03}
                delay={0.4}
                content={markdownify(description)}
              />
            )
          }
        </div>
        <div
          data-aos="fade-in"
          data-aos-delay="400"
          data-aos-duration="900"
          class="flex flex-col items-center justify-center gap-4 sm:flex-row">
          {
            subscription?.enable && config.settings.navigationButton.enable && (
              <HeroSubscription />
            )
          }
          {
            buttons &&
              buttons.map((button) => (
                <ButtonLink
                  content={button}
                  class:list={[
                    "btn-md btn-has-icon group relative z-0 flex w-full items-center justify-center gap-4 sm:w-auto [&>.label]:z-20",
                    button.variant === "secondary"
                      ? "btn-outline-secondary"
                      : "btn-solid-primary",
                  ]}>
                  <span class="flex h-6 w-12 items-center justify-center rounded-full bg-white/15">
                    <SvgIcon
                      icon={button.icon || "star"}
                      class="h-5 w-5 transition-all duration-300 group-hover:rotate-180"
                    />
                  </span>
                </ButtonLink>
              ))
          }
        </div>
      </div>
    </div>
    {
      image && (
        <div
          data-aos="fade-up-sm"
          data-aos-overlap="0.025"
          data-aos-offset="0"
          class="relative mx-auto mt-12 -mb-4 max-w-6xl px-4 md:mt-14 md:mb-0 md:px-4 lg:mt-20 lg:px-5">
          <BlueprintsScroller
            content={customers}
            class="mx-auto mb-8 max-w-4xl"
          />
          <div class="bg-body relative z-10 overflow-hidden rounded-t-2xl px-0.5 pt-0.5 md:rounded-t-3xl">
            <div class="after:bg-primary/2 relative z-20 overflow-hidden rounded-t-2xl bg-black after:absolute after:inset-0 after:size-full after:rounded-t-2xl after:content-[''] md:rounded-t-3xl">
              <Image
                class="rounded-t-2xl md:rounded-t-3xl"
                src={image}
                alt={"About " + plainify(title || "").toLowerCase()}
                priority
              />
            </div>
            <div
              class="home-banner from-body to-primary absolute top-1/2 left-1/2 z-10 h-screen w-1/2 origin-[0%_15%] bg-linear-to-l"
              aria-hidden="true"
            />
            <div
              class="to-body pointer-events-none absolute inset-x-0 bottom-0 z-30 h-1/3 bg-linear-to-b from-transparent"
              aria-hidden="true"
            />
          </div>
        </div>
      )
    }
  </div>
</section>

<script>
  import { animate } from "motion";

  class QilnTicker extends HTMLElement {
    private interval: ReturnType<typeof setInterval> | null = null;
    private observer: IntersectionObserver | null = null;
    private currentIndex = 0;
    private items: HTMLElement[] = [];

    connectedCallback() {
      if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
      this.items = Array.from(this.querySelectorAll(".ticker-item"));
      if (this.items.length < 2) return;
      this.observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              this.startInterval();
            } else {
              this.stopInterval();
            }
          });
        },
        { threshold: 0 },
      );
      this.observer.observe(this);
    }

    disconnectedCallback() {
      this.stopInterval();
      if (this.observer) {
        this.observer.disconnect();
        this.observer = null;
      }
    }

    private startInterval() {
      if (!this.interval) {
        this.interval = setInterval(() => this.runAnimation(), 3000);
      }
    }

    private stopInterval() {
      if (this.interval) {
        clearInterval(this.interval);
        this.interval = null;
      }
    }

    private runAnimation() {
      const outgoing = this.items[this.currentIndex];
      this.currentIndex = (this.currentIndex + 1) % this.items.length;
      const incoming = this.items[this.currentIndex];
      animate(
        outgoing,
        {
          y: ["0%", "-100%"],
          opacity: [1, 0],
          filter: ["blur(0px)", "blur(4px)"],
        },
        { type: "spring", stiffness: 400, damping: 30 },
      );
      animate(
        incoming,
        {
          y: ["100%", "0%"],
          opacity: [0, 1],
          filter: ["blur(4px)", "blur(0px)"],
        },
        { type: "spring", stiffness: 400, damping: 30 },
      );
    }
  }

  if (!customElements.get("qiln-ticker")) {
    customElements.define("qiln-ticker", QilnTicker);
  }
</script>

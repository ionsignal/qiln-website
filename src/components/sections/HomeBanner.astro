---
import config from ".astro/config.generated.json";
import Image from "@/components/helpers/Image.astro";
// import SvgIcon from "@/components/helpers/SvgIcon.astro";
import Customers from "@/components/sections/Customers.astro";
import ButtonLink from "@/components/buttons/ButtonLink.astro";
import AnimatedText from "@/components/widgets/AnimatedText.astro";
import SubscriptionForm from "@/components/widgets/SubscriptionForm.astro";
import Visualization from "@/components/widgets/Visualization.astro";
import { plainify } from "@/utils/text";
import { overrideObjects } from "@/utils/core";
import { markdownify } from "@/utils/text";
import { fetchEntry } from "@/utils/content";
import type { CollectionEntry } from "astro:content";

type SectionData = CollectionEntry<"sections">["data"];
type Props = {
  content?: SectionData;
};

let defaultContent = (await fetchEntry("sections", "home-banner"))?.data;
let actualContent = overrideObjects({ ...defaultContent }, Astro.props.content);
let { title, badge, customers, description, image, buttons, subscription } =
  actualContent;
---

<section id="home" class="scroll-mt-24 lg:scroll-mt-32">
  <div class="banner-gradient stretched-link relative pt-12 md:pt-24 lg:pt-32">
    <Visualization />
    <div class="container">
      <div class="relative z-10 mx-auto max-w-4xl space-y-10">
        <div class="flex flex-col items-center gap-y-8 text-center md:gap-y-10">
          {
            badge && (
              <div
                class="animated-text"
                data-duration="0.6"
                data-delay="0.2"
                data-stagger="0.1">
                <div
                  class="word inline-flex items-center gap-2 rounded-md border border-white/10 bg-black/50 px-4 py-2 font-mono text-sm shadow-lg backdrop-blur-sm md:text-base"
                  style="will-change: transform; transform: translateY(10px); opacity: 0; filter: blur(10px);">
                  <span class="sr-only">Tag: {badge}</span>
                  <span aria-hidden="true" class="text-secondary">
                    $
                  </span>
                  <span aria-hidden="true" class="text-white/90 lowercase">
                    {badge}
                  </span>
                  <span aria-hidden="true" class="text-secondary animate-blink">
                    _
                  </span>
                </div>
              </div>
            )
          }
          <div class="relative inline-block">
            {
              title && (
                <AnimatedText
                  class="has-italic-text font-secondary text-center text-5xl text-white capitalize md:text-7xl/tight"
                  content={markdownify(title)}
                />
              )
            }
          </div>
          {
            description && (
              <AnimatedText
                class="[&_strong]:text-secondary [&_b]:text-secondary mx-auto max-w-2xl text-center text-lg/normal text-white/80 [&_strong]:font-bold"
                stagger={0.03}
                delay={0.4}
                content={markdownify(description)}
              />
            )
          }
        </div>
        <div
          data-aos="fade-in"
          data-aos-delay="400"
          data-aos-duration="900"
          class="flex flex-col items-center justify-center gap-5 sm:flex-row">
          {
            subscription?.enable && config.settings.navigationButton.enable && (
              <SubscriptionForm layout="hero" idSuffix="hero" />
            )
          }
          {
            buttons &&
              buttons.map((button) => (
                <ButtonLink
                  content={button}
                  class:list={[
                    // "btn-md btn-has-icon group relative z-0 flex w-full items-center justify-center gap-4 sm:w-auto [&>.label]:z-20",
                    // button.variant === "secondary"
                    //   ? "btn-outline-secondary"
                    //   : "btn-solid-primary",
                    "btn-md btn-has-icon group relative z-0 flex w-full items-center justify-center gap-4 sm:w-72 [&>.label]:z-20",
                    "btn-solid-secondary",
                  ]}>
                  {/* <span class="flex h-6 w-12 items-center justify-center rounded-full bg-white/15">
                    <SvgIcon
                      icon={button.icon || "star"}
                      class="h-5 w-5 transition-all duration-300 group-hover:rotate-180"
                    />
                  </span> */}
                </ButtonLink>
              ))
          }
        </div>
        <Customers
          content={customers}
          data-aos-delay="600"
          data-aos-duration="900"
          data-aos="fade-in"
        />
      </div>
    </div>
    {
      image && (
        <div
          data-aos="fade-up-sm"
          data-aos-offset="0"
          class="relative mx-auto mt-12 -mb-4 max-w-6xl px-4 md:mt-28 md:mb-0 md:px-4 lg:px-5">
          <div class="bg-body relative z-10 overflow-hidden rounded-t-2xl px-0.5 pt-0.5 md:rounded-t-3xl">
            <div class="after:bg-primary/2 relative z-20 overflow-hidden rounded-t-2xl bg-black after:absolute after:inset-0 after:size-full after:rounded-t-2xl after:content-[''] md:rounded-t-3xl">
              <Image
                class="rounded-t-2xl md:rounded-t-3xl"
                src={image}
                alt={"About " + plainify(title || "").toLowerCase()}
                priority
              />
            </div>
            <div
              class="home-banner from-body to-primary absolute top-1/2 left-1/2 z-10 h-screen w-1/2 origin-[0%_15%] bg-linear-to-l"
              aria-hidden="true"
            />
            <div
              class="to-body pointer-events-none absolute inset-x-0 bottom-0 z-30 h-1/3 bg-linear-to-b from-transparent"
              aria-hidden="true"
            />
          </div>
        </div>
      )
    }
  </div>
</section>

---
import { fetchEntry } from "@/utils/content";
import { markdownify } from "@/utils/text";
import Image from "@/components/helpers/Image.astro";
import LucideIcon from "@/components/helpers/LucideIcon.astro";
import Subtitle from "@/components/widgets/Subtitle.astro";
import type { CollectionEntry } from "astro:content";

type SectionData = CollectionEntry<"sections">["data"];
type Props = {
  content?: SectionData;
  imagePosition?: "left" | "right";
  class?: string;
};

let defaultContent = (await fetchEntry("sections", "feature-gpu"))?.data;
let actualContent =
  Astro.props.content || defaultContent || ({} as SectionData);
let {
  enable = true,
  title,
  subtitle,
  description,
  features,
  image,
} = actualContent;
const { imagePosition = "right", class: className } = Astro.props;
---

{
  enable && (
    <section
      class:list={[
        "feature-split relative w-full overflow-hidden",
        "scroll-mt-24 lg:scroll-mt-32",
        className,
      ]}
      data-direction={imagePosition}>
      <div class="container py-16 lg:py-24">
        <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:items-center lg:gap-16 xl:gap-20">
          <div
            class:list={[
              "motion-text opacity-0 will-change-transform",
              imagePosition === "left" ? "lg:order-2" : "lg:order-1",
            ]}>
            <div class="mx-auto flex max-w-xl flex-col gap-6">
              {subtitle && <Subtitle content={subtitle} />}
              {title && (
                <h2
                  class="has-italic-text capitalize"
                  set:html={markdownify(title)}
                />
              )}
              {description && (
                <p
                  class="text-text-default text-lg leading-relaxed opacity-80"
                  set:html={markdownify(description)}
                />
              )}
              {features && features.length > 0 && (
                <ul class="mt-2 flex flex-col gap-3">
                  {features.map((feature) => (
                    <li class="flex items-start gap-3">
                      <LucideIcon
                        icon="CheckCircle2"
                        class="text-primary mt-0.5 h-5 w-5 shrink-0"
                      />
                      <span
                        class="text-sm text-white/70"
                        set:html={markdownify(feature)}
                      />
                    </li>
                  ))}
                </ul>
              )}
            </div>
          </div>
          <div
            class:list={[
              "motion-image relative opacity-0 will-change-transform",
              imagePosition === "left" ? "lg:order-1" : "lg:order-2",
            ]}>
            {image && (
              <>
                <div
                  aria-hidden="true"
                  class:list={[
                    "bg-[radial-gradient(50%_50%_at_50%_50%,--theme(--color-primary/20%)_0%,transparent_100%)] pointer-events-none absolute inset-0 -z-10 scale-110",
                    imagePosition === "right"
                      ? "translate-x-8 translate-y-10 lg:translate-x-16 lg:translate-y-16"
                      : "-translate-x-8 translate-y-10 lg:-translate-x-16 lg:translate-y-16",
                  ]}
                />
                <div class="relative overflow-hidden rounded-2xl bg-white/2 shadow-2xl ring-1 ring-white/10">
                  <Image
                    src={image}
                    alt="Feature screenshot"
                    class="h-auto w-full"
                  />
                </div>
              </>
            )}
          </div>
        </div>
      </div>
    </section>
  )
}

<script>
  import { animate, inView } from "motion";

  document.addEventListener("DOMContentLoaded", () => {
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
    const sections = document.querySelectorAll(".feature-split");
    sections.forEach((section) => {
      const textEl = section.querySelector(".motion-text");
      const imageEl = section.querySelector(".motion-image");
      const direction = section.getAttribute("data-direction");
      inView(
        section,
        () => {
          if (textEl) {
            animate(
              textEl,
              { opacity: [0, 1], y: [30, 0] },
              { duration: 0.8, ease: "easeOut" },
            );
          }
          if (imageEl) {
            const xOffset = direction === "left" ? -40 : 40;
            animate(
              imageEl,
              { opacity: [0, 1], scale: [1.04, 1], x: [xOffset, 0] },
              {
                type: "spring",
                bounce: 0.3,
                duration: 0.9,
                delay: 0.1,
              },
            );
          }
        },
        { amount: 0.2 },
      );
    });
  });
</script>
